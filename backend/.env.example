# Extra CORS origins (comma-separated)
CORS_ORIGINS=

MAIL_VERIFY_TIMEOUT_MS=8000
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=google_app_password
EMAIL_FROM="SGT Wallet <your.email@gmail.com>"

