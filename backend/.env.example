PORT=5001
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/sgt_wallet
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRES_IN=7d

# Deployed frontend (Vercel)
